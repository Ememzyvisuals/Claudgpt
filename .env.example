# ── GROQ AI ──────────────────────────────────────────────────
# Get free API keys at: https://console.groq.com
# Create at least 3 keys for automatic rotation/failover

GROQ_API_KEY_1=gsk_your_first_key_here
GROQ_API_KEY_2=gsk_your_second_key_here
GROQ_API_KEY_3=gsk_your_third_key_here

# Default model (used for chat streaming — fast responses)
# Smart routing automatically uses best model per agent task:
#   Coding/Debugging  → moonshotai/kimi-k2-0905-instruct  (best open-source coder 2026)
#   Planning/Review   → openai/gpt-oss-120b               (frontier reasoning, beats o4-mini)
#   Chat/Streaming    → llama-3.3-70b-versatile           (fast, reliable)
#   Analysis/Search   → qwen/qwen3-32b                    (thinking mode)
GROQ_MODEL=llama-3.3-70b-versatile

# ── SUPABASE ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── BACKEND SERVER ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_min_32_characters
ALLOWED_ORIGINS=http://localhost:3000,https://claudgpt.vercel.app

# ── FRONTEND ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── APP IDENTITY ──────────────────────────────────────────────
APP_NAME=ClaudGPT
CREATOR_NAME=Emmanuel ARIYO
CREATOR_ALIAS=Emmanuel.A
COMPANY_NAME=EMEMZYVISUALS DIGITALS
